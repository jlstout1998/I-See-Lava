{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track Minecraft versions via Fabric Mappings (reliable source for bots)",
      "fileMatch": ["gradle/libs.versions.toml"],
      "matchStrings": [
        "minecraft\\s*=\\s*\"(?<currentValue>.*)\""
      ],
      "depNameTemplate": "com.mojang:minecraft",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "FabricMC/minecraft-mappings"
    }
  ],
  "packageRules": [
    {
      "description": "Group Fabric and Minecraft updates together",
      "matchPackagePatterns": ["net.fabricmc", "com.mojang"],
      "groupName": "Fabric Stack"
    },
    {
      "description": "Fabric Components Lookup",
      "matchDatasources": ["maven"],
      "matchPackagePatterns": ["net.fabricmc"],
      "registryUrls": [
        "https://maven.fabricmc.net/",
        "https://repo1.maven.org/maven2/"
      ],
      "groupName": "Fabric Stack"
    },
    {
      "description": "Always update the Gradle wrapper",
      "matchPackageNames": ["gradle"],
      "enabled": true
    }
  ],
  "timezone": "UTC",
  "schedule": ["at any time"]
}
