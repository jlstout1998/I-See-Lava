{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group Fabric and Minecraft updates and define their registries",
      "matchDatasources": ["maven"],
      "matchPackagePatterns": [
        "net.fabricmc",
        "com.mojang"
      ],
      "groupName": "Fabric Stack",
      "registryUrls": [
        "https://maven.fabricmc.net/",
        "https://libraries.minecraft.net/",
        "https://repo1.maven.org/maven2/"
      ]
    },
    {
      "description": "Handle Minecraft snapshot versioning",
      "matchPackageNames": ["com.mojang:minecraft"],
      "versioning": "loose"
    },
    {
      "description": "Always update the Gradle wrapper",
      "matchPackageNames": ["gradle"],
      "enabled": true
    }
  ],
  "timezone": "UTC",
  "schedule": ["at any time"]
}
