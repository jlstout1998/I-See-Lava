{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track Minecraft versions using DockerHub tags (very stable for bots)",
      "fileMatch": ["gradle/libs.versions.toml"],
      "matchStrings": [
        "minecraft\\s*=\\s*\"(?<currentValue>.*)\""
      ],
      "depNameTemplate": "minecraft",
      "datasourceTemplate": "docker",
      "packageNameTemplate": "itzg/minecraft-server"
    }
  ],
  "packageRules": [
    {
      "description": "Group everything into the Fabric Stack",
      "matchPackageNames": ["minecraft", "net.fabricmc:**", "com.mojang:**"],
      "groupName": "Fabric Stack"
    },
    {
      "description": "Fabric Maven Registry",
      "matchPackagePatterns": ["net.fabricmc"],
      "registryUrls": ["https://maven.fabricmc.net/"]
    },
    {
      "description": "Enable Gradle updates",
      "matchPackageNames": ["gradle"],
      "enabled": true
    }
  ],
  "timezone": "UTC",
  "schedule": ["at any time"]
}
