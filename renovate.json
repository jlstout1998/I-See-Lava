{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Minecraft Game Lookup",
      "matchDatasources": ["maven"],
      "matchPackageNames": ["com.mojang:minecraft"],
      "registryUrls": ["https://libraries.minecraft.net/"],
      "versioning": "loose",
      "groupName": "Fabric Stack"
    },
    {
      "description": "Fabric Components Lookup",
      "matchDatasources": ["maven"],
      "matchPackagePatterns": ["net.fabricmc"],
      "registryUrls": [
        "https://maven.fabricmc.net/",
        "https://repo1.maven.org/maven2/"
      ],
      "groupName": "Fabric Stack"
    },
    {
      "description": "Always update the Gradle wrapper",
      "matchPackageNames": ["gradle"],
      "enabled": true
    }
  ],
  "timezone": "UTC",
  "schedule": ["at any time"]
}
